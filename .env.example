# ─────────────────────────────────────────
# Copie ce fichier en ".env.local" pour tester en local
# Dans Vercel : Settings → Environment Variables → importe ce fichier
# ─────────────────────────────────────────

# 1. RESEND — formulaire de contact
#    Crée ton compte sur https://resend.com (gratuit)
#    Puis : API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2. GITHUB TOKEN — optionnel, augmente la limite de l'API GitHub (60 → 5000 req/h)
#    https://github.com/settings/tokens → Generate new token (classic)
#    Coche uniquement : public_repo (read)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 3. VERCEL KV — compteur de visites
#    Dashboard Vercel → Storage → Create Database → KV
#    Ces valeurs sont générées automatiquement par Vercel quand tu lies le KV
KV_REST_API_URL=https://xxxxxxxx.kv.vercel-storage.com
KV_REST_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
